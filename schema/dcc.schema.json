{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "ActionsConfig": {
      "additionalProperties": false,
      "properties": {
        "allow": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "confirmPhraseForTiers": {
          "items": {
            "enum": ["sandbox", "shared", "prod-like"],
            "type": "string"
          },
          "type": "array"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["enabled", "allow"],
      "title": "Actions",
      "type": "object"
    },
    "ApiConfig": {
      "additionalProperties": false,
      "properties": {
        "auth": {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "bearer",
              "type": "string"
            },
            "tokenEnv": {
              "description": "Name of the env var holding the credential — never the credential itself (§10.2).",
              "minLength": 1,
              "type": "string"
            }
          },
          "required": ["kind", "tokenEnv"],
          "type": "object"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "enum": ["openapi", "graphql"],
          "type": "string"
        },
        "url": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["id", "type", "url"],
      "title": "API",
      "type": "object"
    },
    "DashboardConfig": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "provider": {
          "minLength": 1,
          "type": "string"
        },
        "uid": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["id", "provider", "uid"],
      "title": "Dashboard",
      "type": "object"
    },
    "EnvironmentConfig": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "type": "string"
        },
        "namespaces": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "projectIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "provider": {
          "minLength": 1,
          "type": "string"
        },
        "tier": {
          "enum": ["sandbox", "shared", "prod-like"],
          "type": "string"
        },
        "workers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": ["id", "label", "provider", "tier"],
      "title": "Environment",
      "type": "object"
    },
    "HealthCheckConfig": {
      "additionalProperties": false,
      "properties": {
        "expectStatus": {
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "url": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["id", "name", "url"],
      "title": "Health check",
      "type": "object"
    },
    "ProviderConfig": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "type": "string"
        },
        "auth": {
          "anyOf": [
            {
              "const": "gh-cli",
              "type": "string"
            },
            {
              "additionalProperties": false,
              "properties": {
                "tokenEnv": {
                  "description": "Name of the env var holding the credential — never the credential itself (§10.2).",
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": ["tokenEnv"],
              "type": "object"
            }
          ]
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "kind": {
          "minLength": 1,
          "type": "string"
        },
        "kubeContext": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "reportUrl": {
          "type": "string"
        },
        "teamId": {
          "type": "string"
        },
        "tokenEnv": {
          "description": "Name of the env var holding the credential — never the credential itself (§10.2).",
          "minLength": 1,
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": ["id", "kind"],
      "title": "Provider",
      "type": "object"
    },
    "ProvidersConfig": {
      "additionalProperties": false,
      "properties": {
        "deployment": {
          "items": {
            "$ref": "#/definitions/ProviderConfig"
          },
          "type": "array"
        },
        "external": {
          "items": {
            "$ref": "#/definitions/ProviderConfig"
          },
          "type": "array"
        },
        "git": {
          "items": {
            "$ref": "#/definitions/ProviderConfig"
          },
          "type": "array"
        },
        "observability": {
          "items": {
            "$ref": "#/definitions/ProviderConfig"
          },
          "type": "array"
        }
      },
      "title": "Providers",
      "type": "object"
    },
    "RepositoryConfig": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "owner": {
          "minLength": 1,
          "type": "string"
        },
        "provider": {
          "minLength": 1,
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": ["id", "provider", "owner", "name"],
      "title": "Repository",
      "type": "object"
    },
    "ServiceConfig": {
      "additionalProperties": false,
      "properties": {
        "apis": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "baseUrls": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "dependsOn": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "repository": {
          "minLength": 1,
          "type": "string"
        },
        "workloadSelector": {
          "additionalProperties": false,
          "properties": {
            "labels": {
              "additionalProperties": {
                "type": "string"
              },
              "propertyNames": {
                "type": "string"
              },
              "type": "object"
            },
            "namespace": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": ["id"],
      "title": "Service",
      "type": "object"
    },
    "UiConfig": {
      "additionalProperties": false,
      "properties": {
        "pollingSeconds": {
          "additionalProperties": {
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "title": "UI",
      "type": "object"
    },
    "WorkspaceConfig": {
      "additionalProperties": false,
      "properties": {
        "defaultEnvironment": {
          "minLength": 1,
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": ["name"],
      "title": "Workspace",
      "type": "object"
    }
  },
  "description": "Workspace configuration for the Developer Control Center (dcc.config.json, spec §4.1).",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "actions": {
      "allOf": [
        {
          "$ref": "#/definitions/ActionsConfig"
        }
      ]
    },
    "apis": {
      "items": {
        "$ref": "#/definitions/ApiConfig"
      },
      "type": "array"
    },
    "dashboards": {
      "items": {
        "$ref": "#/definitions/DashboardConfig"
      },
      "type": "array"
    },
    "environments": {
      "items": {
        "$ref": "#/definitions/EnvironmentConfig"
      },
      "type": "array"
    },
    "healthChecks": {
      "items": {
        "$ref": "#/definitions/HealthCheckConfig"
      },
      "type": "array"
    },
    "providers": {
      "allOf": [
        {
          "$ref": "#/definitions/ProvidersConfig"
        }
      ]
    },
    "repositories": {
      "items": {
        "$ref": "#/definitions/RepositoryConfig"
      },
      "type": "array"
    },
    "services": {
      "items": {
        "$ref": "#/definitions/ServiceConfig"
      },
      "type": "array"
    },
    "ui": {
      "allOf": [
        {
          "$ref": "#/definitions/UiConfig"
        }
      ]
    },
    "workspace": {
      "$ref": "#/definitions/WorkspaceConfig"
    }
  },
  "required": ["workspace"],
  "title": "DCC configuration",
  "type": "object"
}
