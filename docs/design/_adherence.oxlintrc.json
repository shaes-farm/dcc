{
  "plugins": ["react", "import"],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/panels/**",
              "components/status/**",
              "ui_kits/dcc-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: message, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='ErrorCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|detail|action|key|ref|className|style|children)$/]",
        "message": "<ErrorCard> doesn't accept that prop. Declared props: title, detail, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|active|disabled|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, children, active, disabled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:mono|invalid|placeholder|value|onChange|type|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: mono, invalid, placeholder, value, onChange, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|asOf|actions|pad|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, asOf, actions, pad, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|mono|value|onChange|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, mono, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:healthy|degraded|failing|deploying|unknown)$/]",
        "message": "<StatusBadge> status must be one of 'healthy' | 'degraded' | 'failing' | 'deploying' | 'unknown'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:workspace|preset|polling|issues|clock|key|ref|className|style|children)$/]",
        "message": "<StatusBar> doesn't accept that prop. Declared props: workspace, preset, polling, issues, clock."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:healthy|degraded|failing|deploying|unknown)$/]",
        "message": "<StatusDot> status must be one of 'healthy' | 'degraded' | 'failing' | 'deploying' | 'unknown'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='UriChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:uri|onClick|key|ref|className|style|children)$/]",
        "message": "<UriChip> doesn't accept that prop. Declared props: uri, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/index.js"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
